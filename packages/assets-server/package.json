{
  "name": "@lineage2js/assets-server",
  "version": "0.0.1",
  "description": "Static asset server for game icons (skills/items/actions/classes) -- kept out of git, served with Cache-Control + ETag revalidation",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src/**",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
