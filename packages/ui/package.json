    "lint": "eslint src/**",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lineage2js/network": "workspace:*",
    "@react-three/fiber": "^8.17.10",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  }
}
