{
  "name": "@lineage2js/ui",
  "version": "0.0.1",
  "description": "Lineage 2 web UI client",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build --base=/lineage2js-ui/",
