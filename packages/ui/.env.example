VITE_REGISTER_URL=
VITE_RESTORE_PASSWORD_URL=
VITE_WIKI_URL=

# "{id}" is replaced with the actual id. Matches packages/assets-server's
# assets/highfive/icons/{skills,items,actions,classes} layout, e.g. served
# locally via `pnpm --filter @lineage2js/assets-server dev` on port 4000:
# VITE_SKILL_ICON_BASE_URL=http://localhost:4000/highfive/icons/skills/{id}.png
VITE_SKILL_ICON_BASE_URL=
VITE_ITEM_ICON_BASE_URL=
VITE_ACTION_ICON_BASE_URL=
VITE_CLASS_ICON_BASE_URL=

# Login screen background. Matches packages/assets-server's
# assets/legacy/{images,videos}/titlescreens layout. "{id}" is replaced with
# a random number in [1, N], where N is fetched from the server's sibling
# "count" endpoint (e.g. GET .../legacy/images/titlescreens/count), not a
# build-time env var. Video takes priority over image when both are
# available. If neither is set/available, the login screen falls back to the
# r3f atmosphere scene alone.
# VITE_LOGIN_BACKGROUND_IMAGE_BASE_URL=http://localhost:4000/legacy/images/titlescreens/{id}.jpg
# VITE_LOGIN_BACKGROUND_VIDEO_BASE_URL=http://localhost:4000/legacy/videos/titlescreens/{id}.mp4
VITE_LOGIN_BACKGROUND_IMAGE_BASE_URL=
VITE_LOGIN_BACKGROUND_VIDEO_BASE_URL=
